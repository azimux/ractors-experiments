#!/usr/bin/env ruby

require "benchmark"
require "bigdecimal"
# require "pry"

srand(0)

CONCURRENCY = 3
# Is this basically Math::E or related?? And just off a bit due to randomness?
RANDOM_NUMBER_UPPER_BOUND = 2.78
RANDOM_NUMBERS = 10_000.times.map { BigDecimal(rand * RANDOM_NUMBER_UPPER_BOUND) }

module Benchmarkable
  def do_it
    product = 1

    loop do
      number = get

      break if number == :stop

      product *= number
    end

    product
  end

  def get = raise "subclass responsibility"
  def <<(...) = raise "subclass responsibility"
  def join = raise "subclass responsibility"
  def value = raise "subclass responsibility"
end

def benchmark(method_name, silent: false)
  answer = nil

  unless silent
    puts "benchmarking #{method_name}"
  end

  GC.start
  GC.compact

  GC.disable

  elapsed_time = Benchmark.measure do
    answer = send("#{method_name}_benchmark")
  end.real

  unless silent
    puts "answer: #{answer.to_s[0...10]}...#{answer.to_s[-10...-1]}"
    puts "%.4f seconds" % elapsed_time
    puts
  end

  elapsed_time
ensure
  GC.enable
end

def direct_benchmark
  queues = CONCURRENCY.times.map { Queue.new }

  RANDOM_NUMBERS.each.with_index do |number, index|
    queues[index % CONCURRENCY] << number
  end

  queues.each { |queue| queue << :stop }

  products = []

  queues.each do |queue|
    product = 1

    loop do
      number = queue.pop

      break if number == :stop

      product *= number
    end

    products << product
  end

  products.inject(:*)
end

def ractor_benchmark
  ractors = CONCURRENCY.times.map do
    Ractor.new do
      product = 1

      loop do
        number = receive

        break if number == :stop

        product *= number
      end

      product
    end
  end

  RANDOM_NUMBERS.each.with_index do |number, index|
    ractors[index % CONCURRENCY] << number
  end

  ractors.each { it << :stop }

  ractors.map(&:value).inject(:*)
end

class ThreadProductizer
  include Benchmarkable

  attr_accessor :queue, :thread

  def initialize(...)
    self.queue = Queue.new
    self.thread = Thread.new { do_it }
  end

  def get = queue.pop
  def <<(...) = queue.<<(...)
  def join = thread.join
  def value = thread.value
end

def thread_benchmark
  threads = CONCURRENCY.times.map do
    ThreadProductizer.new
  end

  RANDOM_NUMBERS.each.with_index do |number, index|
    threads[index % CONCURRENCY] << number
  end

  threads.each { |thread| thread << :stop }

  threads.each(&:join).map(&:value).inject(:*)
end

benchmarks = [:direct, :ractor, :thread]

puts "warming up..."

benchmarks.each do |method_name|
  benchmark(method_name, silent: true)
end
benchmarks.reverse.each do |method_name|
  benchmark(method_name, silent: true)
end

puts "ok here we go..."

benchmark(:direct)
ractor_elapsed_time = benchmark(:ractor)
thread_elapsed_time = benchmark(:thread)

ractors_speedup = 1 - (ractor_elapsed_time / thread_elapsed_time)

puts "Ractors speedup: %d%%" % (100 * ractors_speedup).round
